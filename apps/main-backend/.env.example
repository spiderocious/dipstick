NODE_ENV=development
PORT=8091
LOG_LEVEL=info

APP_BASE_URL=http://localhost:8091
WEB_BASE_URL=http://localhost:5173

MONGO_URL=mongodb://127.0.0.1:27017
MONGO_DB_NAME=dipstick

JWT_ACCESS_SECRET=replace_me_with_a_long_random_string_at_least_32_chars
JWT_REFRESH_SECRET=replace_me_with_a_long_random_string_at_least_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

OTP_TTL_SECONDS=600
OTP_MAX_ATTEMPTS=5

# Verification policy at sign-up: none | email | phone | both
# none  → auto-verify, tokens issued immediately (no OTP)
# email → must verify email; phone → must verify phone; both → must verify both
AUTH_VERIFICATION=phone
